#: core-modules/dashboard/dashboard.php:35
msgid "Dashboard"
msgstr "داشبورد"

#: core-modules/dashboard/dashboard.php:66
msgid "Welcome to your Control Center"
msgstr "مرکز کنترل شما آماده است"

#: core-modules/dashboard/dashboard.php:67
msgid ""
"This is the central hub for all WandTech features. From here, you can manage "
"powerful tools that enhance your WordPress site. Use the tabs above to "
"navigate and configure your modules."
msgstr ""
"این مرکز اصلی تمام قابلیت‌های WandTech است. از اینجا می‌توانید ابزارهای "
"قدرتمندی را مدیریت کنید که سایت وردپرس شما را بهبود می‌بخشند. از تب‌های بالا "
"برای جابجایی و پیکربندی ماژول‌ها استفاده کنید."

#: core-modules/dashboard/dashboard.php:70
msgid "System Status At a Glance"
msgstr "وضعیت وند تک در یک نگاه"

#: core-modules/dashboard/dashboard.php:76
msgid "Total Modules Available"
msgstr "مجموع ماژول‌ها"

#: core-modules/dashboard/dashboard.php:83
msgid "Active Modules"
msgstr "ماژول‌های فعال"

#: core-modules/dashboard/dashboard.php:90
msgid "Inactive Modules"
msgstr "ماژول‌های غیرفعال"

#: core-modules/dashboard/dashboard.php:97
msgid "Performance Optimizations"
msgstr "بهینه‌سازی پرفورمنس"

#. translators: %d is the number of admin-only modules.
#: core-modules/dashboard/dashboard.php:109
#, php-format
msgid ""
"To keep your site fast for visitors, we prevented %d admin-specific module "
"from loading on the frontend."
msgid_plural ""
"To keep your site fast for visitors, we prevented %d admin-specific modules "
"from loading on the frontend."
msgstr[0] ""
"برای حفظ سرعت سایت برای بازدیدکنندگان، از بارگذاری %d ماژول مخصوص مدیر در "
"فرانت‌اند جلوگیری کردیم."
msgstr[1] ""
"برای حفظ سرعت سایت برای بازدیدکنندگان، از بارگذاری %d ماژول مخصوص مدیر در "
"فرانت‌اند جلوگیری کردیم."

#: core-modules/module-installer/module-installer.php:54
msgid "Install Module"
msgstr "نصب ماژول"

#: core-modules/module-installer/module-installer.php:72
msgid "Close"
msgstr "بستن"

#: core-modules/module-installer/module-installer.php:73
msgid "Install a New Module"
msgstr "نصب یک ماژول جدید"

#: core-modules/module-installer/module-installer.php:74
msgid "Upload a module in a .zip format to install it."
msgstr "یک ماژول با فرمت .zip آپلود کنید تا نصب شود."

#: core-modules/module-installer/module-installer.php:80
msgid "The module must be a correctly formatted .zip file."
msgstr "ماژول باید یک فایل .zip با فرمت صحیح باشد."

#: core-modules/module-installer/module-installer.php:86
#: includes/class-wandtech-console-admin.php:107
msgid "Install Now"
msgstr "نصب کن"

#: core-modules/module-installer/module-installer.php:103
#: includes/class-wandtech-console-ajax.php:35
#: includes/class-wandtech-console-ajax.php:63
#: includes/class-wandtech-console-ajax.php:101
msgid "Security check failed or insufficient permissions."
msgstr "دسترسی کافی نیست."

#: core-modules/module-installer/module-installer.php:108
msgid "No file was uploaded or an error occurred during upload."
msgstr "فایل آپلود نشد یا خطایی در آپلود رخ داد."

#: core-modules/module-installer/module-installer.php:111
#: includes/class-wandtech-console-ajax.php:41
msgid "Invalid file type. Only .zip files are allowed."
msgstr "نوع فایل نامعتبر است. تنها فایل‌های .zip مجاز هستند."

#: core-modules/module-installer/module-installer.php:125
#, php-format
msgid "Failed to unzip file: %s"
msgstr "عدم توانایی در اکسترکت فایل: %s"

#: core-modules/module-installer/module-installer.php:140
msgid ""
"Could not move the module to the correct directory. This may be a file "
"permission issue."
msgstr ""
"امکان انتقال ماژول به پوشه مورد نظر وجود ندارد. احتمالاً مشکل مربوط به دسترسی "
"فایل‌ها است."

#: core-modules/module-installer/module-installer.php:142
#: includes/class-wandtech-console-ajax.php:54
msgid "Module installed successfully! The page will now reload."
msgstr "ماژول با موفقیت نصب شد! صفحه اکنون بارگذاری مجدد می‌شود."

#: core-modules/module-installer/module-installer.php:157
msgid "The ZIP file does not contain a valid module directory structure."
msgstr "فایل ZIP شامل ساختار پوشه ماژول معتبر نیست."

#: core-modules/module-installer/module-installer.php:162
#, php-format
msgid "Invalid module structure. The required file \"%s\" is missing."
msgstr "ساختار ماژول نامعتبر است. فایل مورد نیاز «%s» وجود ندارد."

#: core-modules/module-installer/module-installer.php:167
msgid ""
"This does not appear to be a valid WandTech module. The \"Module Name\" "
"header is missing."
msgstr ""
"این به نظر نمی‌رسد یک ماژول معتبر WandTech باشد. هدر \"Module Name\" وجود "
"ندارد."

#: core-modules/module-installer/module-installer.php:170
msgid ""
"This does not appear to be a valid WandTech module. The \"Scope\" header is "
"missing."
msgstr ""
"این به نظر نمی‌رسد یک ماژول معتبر WandTech باشد. هدر \"Scope\" وجود ندارد."

#: core-modules/module-installer/module-installer.php:175
#, php-format
msgid ""
"A module with the slug \"%s\" already exists. Please delete it first if you "
"want to reinstall."
msgstr ""
"ماژولی با شناسه \"%s\" قبلاً وجود دارد. اگر می‌خواهید دوباره نصب کنید، ابتدا "
"آن را حذف کنید."

#: core-modules/module-manager/module-manager.php:31
msgid "Modules"
msgstr "ماژول ها"

#: core-modules/module-manager/module-manager.php:57
